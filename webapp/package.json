{
  "name": "comfyui-workflow-architect",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "pnpm run build",
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:preview": "electron .",
    "electron:build": "pnpm build && electron-builder"
  },
  "build": {
    "appId": "com.fullydigital.ai-architect",
    "productName": "AI Architect",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../comfyui-paths.config.json",
        "to": "comfyui-paths.config.json"
      }
    ],
    "win": {
      "icon": "electron/icons/icon.ico",
      "target": "nsis"
    },
    "mac": {
      "icon": "electron/icons/icon.icns",
      "target": "dmg"
    },
    "linux": {
      "icon": "electron/icons/icon.png",
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "jszip": "^3.10.1",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "react": "18.3.1",
    "react-day-picker": "8.10.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "2.1.7",
    "reactflow": "^11.11.4",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/dagre": "^0.7.53",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^9.0.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "tailwindcss": "4.1.12",
    "typescript": "^5.5.0",
    "vite": "6.3.5",
    "wait-on": "^8.0.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "electron",
      "electron-winstaller",
      "esbuild",
      "protobufjs"
    ]
  }
}
